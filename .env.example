# ============================================================
# .env.example - Template for local development
# Copy this file to .env and fill in every value.
# NEVER commit your real .env file to Git.
# ============================================================

# Neon PostgreSQL Connection
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# n8n Host Configuration
# For local dev use 'localhost'; for Render use your .onrender.com domain
N8N_HOST=
N8N_PORT=5678
N8N_PROTOCOL=https

# The full public URL that webhooks will be built on top of
# Example: https://your-service.onrender.com/
WEBHOOK_URL=

# Security
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Basic Auth credentials for the n8n UI
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Locale & Runners
GENERIC_TIMEZONE=Asia/Kolkata
N8N_RUNNERS_ENABLED=true

# true on Render (HTTPS); false for local HTTP dev
N8N_SECURE_COOKIE=true
